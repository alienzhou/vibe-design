{
  "name": "design-explorer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:client && tsx src/server.ts",
    "build": "npm run build:client && tsc -p tsconfig.json",
    "build:client": "esbuild src/client.ts --bundle --format=iife --target=es2020 --outfile=public/main.js",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
